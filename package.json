{
  "name": "setup-kiota",
  "description": "GitHub Actions TypeScript template",
  "version": "0.5.0",
  "author": "microsoft",
  "private": true,
  "homepage": "https://github.com/microsoft/setup-kiota",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/setup-kiota.git"
  },
  "bugs": {
    "url": "https://github.com/microsoft/setup-kiota/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "kiota",
    "OpenAPI"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "jest",
    "format:write": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "npx eslint .",
    "package": "ncc build src/index.ts --license licenses.txt",
    "package:watch": "npm run package -- --watch",
    "test": "(jest && make-coverage-badge --output-path ./badges/coverage.svg) || make-coverage-badge --output-path ./badges/coverage.svg",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
